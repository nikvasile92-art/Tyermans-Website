---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";

const imageModules = await import.meta.glob<{ default: ImageMetadata }>(
  "../assets/gallery/*.{jpg,JPG,jpeg,JPEG,png,PNG,webp}",
  { eager: true }
);

const photos = Object.values(imageModules)
  .map((m) => m.default)
  .sort((a, b) => a.src.localeCompare(b.src));
---
<Layout title="Car Portfolio — Tyerman's Automotive & Suspension">
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Car Portfolio</span>
      <h1>Your backstage pass.</h1>
      <p>Whether it’s built for Star Command, engineered for superheroes, or dialed in for the Fast & Furious—we handle Hollywood’s finest.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="masonry">
        {photos.map((photo, i) => (
          <button
            class="thumb"
            data-index={i}
            aria-label={`Open photo ${i + 1}`}
            type="button"
          >
            <Image
              src={photo}
              alt={`Tyerman's Automotive shop photo ${i + 1}`}
              widths={[400, 800]}
              sizes="(max-width: 600px) 100vw, (max-width: 900px) 50vw, 33vw"
              loading={i < 9 ? "eager" : "lazy"}
            />
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Lightbox -->
  <div id="lightbox" class="lightbox" role="dialog" aria-modal="true" aria-label="Photo viewer" hidden>
    <button class="lightbox__close" aria-label="Close">×</button>
    <button class="lightbox__nav lightbox__nav--prev" aria-label="Previous photo">‹</button>
    <button class="lightbox__nav lightbox__nav--next" aria-label="Next photo">›</button>
    <figure class="lightbox__figure">
      <img id="lightbox-img" src="" alt="" />
    </figure>
  </div>
</Layout>

<style>
  .page-hero {
    padding: 72px 0 24px;
    background: linear-gradient(180deg, var(--color-bg-subtle) 0%, var(--color-bg) 100%);
  }
  .page-hero p { color: var(--color-text-muted); }

  .masonry {
    columns: 3 280px;
    column-gap: 16px;
  }
  .thumb {
    display: block;
    width: 100%;
    margin: 0 0 16px;
    padding: 0;
    border: 0;
    background: transparent;
    cursor: zoom-in;
    box-shadow: var(--shadow-sm);
    transition: box-shadow 0.2s ease;
    break-inside: avoid;
    -webkit-column-break-inside: avoid;
  }
  .thumb:hover {
    box-shadow: var(--shadow-md);
  }
  .thumb img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .lightbox {
    position: fixed;
    inset: 0;
    background: rgba(8, 12, 22, 0.92);
    color: #fff;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }
  .lightbox[hidden] { display: none; }
  .lightbox__figure {
    margin: 0;
    max-width: min(92vw, 1200px);
    max-height: 92vh;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .lightbox__figure img {
    max-width: 100%;
    max-height: 88vh;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg);
    object-fit: contain;
  }
  .lightbox button {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.18);
    color: #fff;
    border-radius: 999px;
    cursor: pointer;
    transition: background 0.2s ease;
  }
  .lightbox button:hover { background: rgba(255,255,255,0.18); }
  .lightbox__close {
    position: absolute;
    top: 20px;
    right: 20px;
    width: 44px;
    height: 44px;
    font-size: 1.6rem;
    line-height: 1;
  }
  .lightbox__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 52px;
    height: 52px;
    font-size: 2rem;
    line-height: 1;
  }
  .lightbox__nav--prev { left: 20px; }
  .lightbox__nav--next { right: 20px; }

  @media (max-width: 540px) {
    .lightbox__nav { width: 44px; height: 44px; font-size: 1.5rem; }
    .lightbox__nav--prev { left: 8px; }
    .lightbox__nav--next { right: 8px; }
  }
</style>

<script>
  const thumbs = Array.from(document.querySelectorAll<HTMLButtonElement>(".thumb"));
  const lb = document.getElementById("lightbox") as HTMLDivElement | null;
  const lbImg = document.getElementById("lightbox-img") as HTMLImageElement | null;
  if (!lb || !lbImg) { /* not on this page */ } else {
    let current = 0;

    const open = (idx: number) => {
      current = idx;
      const img = thumbs[idx].querySelector("img");
      lbImg.src = img?.src || "";
      lbImg.alt = img?.alt || "";
      lb.hidden = false;
      document.body.style.overflow = "hidden";
    };
    const close = () => {
      lb.hidden = true;
      lbImg.src = "";
      document.body.style.overflow = "";
    };
    const next = (delta: number) => {
      current = (current + delta + thumbs.length) % thumbs.length;
      open(current);
    };

    thumbs.forEach((t) => {
      t.addEventListener("click", () => open(Number(t.dataset.index)));
    });

    lb.querySelector(".lightbox__close")?.addEventListener("click", close);
    lb.querySelector(".lightbox__nav--prev")?.addEventListener("click", () => next(-1));
    lb.querySelector(".lightbox__nav--next")?.addEventListener("click", () => next(1));
    lb.addEventListener("click", (e) => { if (e.target === lb) close(); });
    document.addEventListener("keydown", (e) => {
      if (lb.hidden) return;
      if (e.key === "Escape") close();
      if (e.key === "ArrowLeft") next(-1);
      if (e.key === "ArrowRight") next(1);
    });
  }
</script>
