---
import Layout from "../layouts/Layout.astro";

// Auto-shop / mechanic photos. Replace with your own by dropping
// images into /public/gallery/ and updating the src paths below.
const photos = [
  { src: "https://images.unsplash.com/photo-1486006920555-c77dcf18193c?auto=format&fit=crop&w=1400&q=80", alt: "Mechanic working under a vehicle on a lift" },
  { src: "https://images.unsplash.com/photo-1518295751675-2a94d6232ef9?auto=format&fit=crop&w=1400&q=80", alt: "Car raised on a service lift in a clean shop" },
  { src: "https://images.unsplash.com/photo-1487754180451-c456f719a1fc?auto=format&fit=crop&w=1400&q=80", alt: "Close-up of a wheel and brake assembly during service" },
  { src: "https://images.unsplash.com/photo-1632823469850-1e7e44a5b6f5?auto=format&fit=crop&w=1400&q=80", alt: "Vintage style auto shop sign" },
  { src: "https://images.unsplash.com/photo-1517524206127-48bbd363f3d7?auto=format&fit=crop&w=1400&q=80", alt: "Engine bay being serviced" },
  { src: "https://images.unsplash.com/photo-1503376780353-7e6692767b70?auto=format&fit=crop&w=1400&q=80", alt: "Classic car in a shop" },
  { src: "https://images.unsplash.com/photo-1492144534655-ae79c964c9d7?auto=format&fit=crop&w=1400&q=80", alt: "Mechanic tools laid out on a workbench" },
  { src: "https://images.unsplash.com/photo-1493238792000-8113da705763?auto=format&fit=crop&w=1400&q=80", alt: "Shock absorber suspension component" },
  { src: "https://images.unsplash.com/photo-1635770310348-2c4befb6c5be?auto=format&fit=crop&w=1400&q=80", alt: "Mechanic checking under-hood components" },
  { src: "https://images.unsplash.com/photo-1605152276897-4f618f831968?auto=format&fit=crop&w=1400&q=80", alt: "Brake rotor and caliper detail" },
  { src: "https://images.unsplash.com/photo-1632823471565-1ecdf18e1c0f?auto=format&fit=crop&w=1400&q=80", alt: "Hands of a technician working on a tire" },
  { src: "https://images.unsplash.com/photo-1632823471565-1ecdf18e1c0f?auto=format&fit=crop&w=1400&q=80", alt: "Wheel alignment rack" },
];
---
<Layout title="Photo Album — Tyerman's Automotive & Suspension">
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Photo album</span>
      <h1>Inside the shop.</h1>
      <p>A few snapshots from around the bays. Click any photo to view it larger.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="masonry">
        {photos.map((p, i) => (
          <button
            class="thumb"
            data-index={i}
            data-src={p.src}
            data-alt={p.alt}
            aria-label={`Open photo ${i + 1}: ${p.alt}`}
            type="button"
          >
            <img src={p.src} alt={p.alt} loading="lazy" />
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Lightbox -->
  <div id="lightbox" class="lightbox" role="dialog" aria-modal="true" aria-label="Photo viewer" hidden>
    <button class="lightbox__close" aria-label="Close">×</button>
    <button class="lightbox__nav lightbox__nav--prev" aria-label="Previous photo">‹</button>
    <button class="lightbox__nav lightbox__nav--next" aria-label="Next photo">›</button>
    <figure class="lightbox__figure">
      <img id="lightbox-img" src="" alt="" />
      <figcaption id="lightbox-caption"></figcaption>
    </figure>
  </div>
</Layout>

<style>
  .page-hero {
    padding: 72px 0 24px;
    background: linear-gradient(180deg, #f6f8fb 0%, #ffffff 100%);
  }
  .page-hero p { color: var(--color-text-muted); }

  .masonry {
    columns: 3 280px;
    column-gap: 16px;
  }
  .thumb {
    display: block;
    width: 100%;
    margin: 0 0 16px;
    padding: 0;
    border: 0;
    background: transparent;
    border-radius: var(--radius-md);
    overflow: hidden;
    cursor: zoom-in;
    box-shadow: var(--shadow-sm);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    break-inside: avoid;
  }
  .thumb:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }
  .thumb img {
    width: 100%;
    height: auto;
    display: block;
  }

  .lightbox {
    position: fixed;
    inset: 0;
    background: rgba(8, 12, 22, 0.92);
    color: #fff;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }
  .lightbox[hidden] { display: none; }
  .lightbox__figure {
    margin: 0;
    max-width: min(92vw, 1200px);
    max-height: 92vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }
  .lightbox__figure img {
    max-width: 100%;
    max-height: 80vh;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg);
    object-fit: contain;
  }
  .lightbox__figure figcaption {
    color: rgba(255,255,255,0.85);
    font-size: 0.95rem;
    text-align: center;
  }
  .lightbox button {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.18);
    color: #fff;
    border-radius: 999px;
    cursor: pointer;
    transition: background 0.2s ease;
  }
  .lightbox button:hover { background: rgba(255,255,255,0.18); }
  .lightbox__close {
    position: absolute;
    top: 20px;
    right: 20px;
    width: 44px;
    height: 44px;
    font-size: 1.6rem;
    line-height: 1;
  }
  .lightbox__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 52px;
    height: 52px;
    font-size: 2rem;
    line-height: 1;
  }
  .lightbox__nav--prev { left: 20px; }
  .lightbox__nav--next { right: 20px; }

  @media (max-width: 540px) {
    .lightbox__nav { width: 44px; height: 44px; font-size: 1.5rem; }
    .lightbox__nav--prev { left: 8px; }
    .lightbox__nav--next { right: 8px; }
  }
</style>

<script>
  // Vanilla lightbox — no JS framework needed.
  const thumbs = Array.from(document.querySelectorAll<HTMLButtonElement>(".thumb"));
  const lb = document.getElementById("lightbox") as HTMLDivElement | null;
  const lbImg = document.getElementById("lightbox-img") as HTMLImageElement | null;
  const lbCap = document.getElementById("lightbox-caption") as HTMLElement | null;
  if (!lb || !lbImg || !lbCap) {
    /* not on this page */
  } else {
    let current = 0;

    const open = (idx: number) => {
      current = idx;
      const t = thumbs[idx];
      lbImg.src = t.dataset.src || "";
      lbImg.alt = t.dataset.alt || "";
      lbCap.textContent = t.dataset.alt || "";
      lb.hidden = false;
      document.body.style.overflow = "hidden";
    };
    const close = () => {
      lb.hidden = true;
      lbImg.src = "";
      document.body.style.overflow = "";
    };
    const next = (delta: number) => {
      current = (current + delta + thumbs.length) % thumbs.length;
      open(current);
    };

    thumbs.forEach((t) => {
      t.addEventListener("click", () => open(Number(t.dataset.index)));
    });

    lb.querySelector(".lightbox__close")?.addEventListener("click", close);
    lb.querySelector(".lightbox__nav--prev")?.addEventListener("click", () => next(-1));
    lb.querySelector(".lightbox__nav--next")?.addEventListener("click", () => next(1));
    lb.addEventListener("click", (e) => {
      if (e.target === lb) close();
    });
    document.addEventListener("keydown", (e) => {
      if (lb.hidden) return;
      if (e.key === "Escape") close();
      if (e.key === "ArrowLeft") next(-1);
      if (e.key === "ArrowRight") next(1);
    });
  }
</script>
