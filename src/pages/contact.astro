---
import Layout from "../layouts/Layout.astro";
---
<Layout title="Contact — Tyerman's Automotive & Suspension">
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Contact</span>
      <h1>Stop by, call, or request an appointment&nbsp;online.</h1>
      <p>We're on West Magnolia Boulevard, just east of Hollywood Way. Free street parking out front.</p>
    </div>
  </section>

  <section class="section">
    <div class="container contact-grid">
      <aside class="contact-info">
        <div class="info-block">
          <h3>Visit</h3>
          <p>
            1420 W Magnolia Blvd<br/>
            Burbank, CA 91506
          </p>
          <a href="https://maps.google.com/?q=1420+W+Magnolia+Blvd+Burbank+CA+91506" target="_blank" rel="noopener" class="btn btn--ghost btn--sm">Get directions →</a>
        </div>
        <div class="info-block">
          <h3>Hours</h3>
          <table class="hours">
            <tr><th>Mon</th><td>8:00 AM – 5:00 PM</td></tr>
            <tr><th>Tue</th><td>8:00 AM – 5:00 PM</td></tr>
            <tr><th>Wed</th><td>8:00 AM – 5:00 PM</td></tr>
            <tr><th>Thu</th><td>8:00 AM – 5:00 PM</td></tr>
            <tr><th>Fri</th><td>8:00 AM – 5:00 PM</td></tr>
            <tr><th>Sat</th><td>Closed</td></tr>
            <tr><th>Sun</th><td>Closed</td></tr>
          </table>
        </div>
        <div class="info-block">
          <h3>Get in touch</h3>
          <p>
            <a href="tel:+18188467291">📞 (818) 846-7291</a><br/>
            <a href="mailto:joel@tyermans.com">✉️ joel@tyermans.com</a>
          </p>
          <a href="/appointment" class="btn btn--primary">Request appointment</a>
        </div>
      </aside>

      <div class="contact-map">
        <iframe
          title="Map of 1420 W Magnolia Blvd, Burbank, CA"
          src="https://www.google.com/maps?q=1420+W+Magnolia+Blvd+Burbank+CA+91506&output=embed"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    padding: 72px 0 32px;
    background: linear-gradient(180deg, var(--color-bg-subtle) 0%, var(--color-bg) 100%);
  }
  .page-hero p { color: var(--color-text-muted); max-width: 60ch; }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 32px;
    align-items: start;
  }
  .contact-info { display: grid; gap: 16px; }
  .info-block {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 24px;
    box-shadow: var(--shadow-sm);
  }
  .info-block h3 { margin-bottom: 8px; }
  .info-block p { margin-bottom: 12px; color: var(--color-text-muted); }
  .hours {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.95rem;
  }
  .hours th {
    text-align: left;
    color: var(--color-text-muted);
    font-weight: 500;
    width: 70px;
    padding: 4px 0;
  }
  .hours td { color: var(--color-text); padding: 4px 0; }
  .btn--sm { padding: 8px 14px; font-size: 0.85rem; }

  .contact-map {
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
    background: var(--color-bg-subtle);
    min-height: 460px;
  }
  .contact-map iframe {
    width: 100%;
    height: 100%;
    min-height: 460px;
    border: 0;
    display: block;
  }
  @media (max-width: 820px) {
    .contact-grid { grid-template-columns: 1fr; }
  }
</style>
