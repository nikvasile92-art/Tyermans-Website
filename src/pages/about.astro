---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import aboutImg from "../assets/tyermans-about.jpg";

const milestones = [
  { year: "1948", title: "Tyerman's opens", body: "Dave Tyerman, an engineer at Lockheed, opens a small alignment & suspension shop in Burbank." },
  { year: "1960s", title: "Specialty products", body: "Dave develops a handful of suspension and alignment specialty products that gain a following across Los Angeles." },
  { year: "1970s", title: "13-bay expansion", body: "The shop expands to its current 13-bay layout on West Magnolia Boulevard." },
  { year: "Today", title: "Full-service shop", body: "We've added engine repair, diagnostics, electronic troubleshooting, and brake & suspension upgrades — while staying family-run." },
];
---
<Layout title="About — Tyerman's Automotive & Suspension">
  <section class="page-hero">
    <div class="container about-hero">
      <div>
        <span class="eyebrow">Our story</span>
        <h1>Local auto repair in the heart of Burbank.</h1>
        <p>
         At Tyermans Automotive, we are passionate about delivering exceptional auto repair and maintenance services with uncompromising quality and integrity. Located in the heart of Burbank, we pride ourselves on being a premier full-service independent shop that specializes in keeping vehicles running at their absolute best.
        </p>
        <p>
          Our team of highly skilled, ASE-certified technicians brings extensive expertise to every job, whether it’s routine maintenance, complex diagnostics, or performance upgrades. We combine state-of-the-art diagnostic equipment with premium parts and proven repair techniques to ensure your vehicle receives the highest standard of care.
        </p>
      </div>
      <div class="about-hero__media" aria-hidden="true">
        <Image
          src={aboutImg}
          alt="Tyerman's Automotive & Suspension shop"
          loading="eager"
          widths={[600, 900, 1200]}
          sizes="(max-width: 880px) 100vw, 50vw"
        />
      </div>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container">
      <div class="grid grid--3">
        <article class="card">
          <span class="icon-circle">⚙️</span>
          <h3>Specialists, not generalists</h3>
          <p>Our techs grew up under cars. Suspension and alignment are in our DNA — we'll find pulls and noises other shops can't.</p>
        </article>
        <article class="card">
          <span class="icon-circle">🤝</span>
          <h3>Honest estimates</h3>
          <p>We diagnose, then call you with options before any extra work happens. No surprise charges at pickup.</p>
        </article>
        <article class="card">
          <span class="icon-circle">🏡</span>
          <h3>Local for life</h3>
          <p>We sponsor our local high school teams and know our customers by name and by car. We're here for the long haul.</p>
        </article>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    padding: 72px 0;
    background: linear-gradient(180deg, var(--color-bg-subtle) 0%, var(--color-bg) 100%);
  }
  .about-hero {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 48px;
    align-items: center;
  }
  .about-hero p {
    color: var(--color-text-muted);
    font-size: 1.05rem;
  }
  .about-hero__media img {
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    width: 100%;
    height: auto;
    display: block;
  }
  @media (max-width: 880px) {
    .about-hero { grid-template-columns: 1fr; }
  }

  .timeline {
    list-style: none;
    padding: 0;
    margin: 32px 0 0;
    display: grid;
    gap: 16px;
  }
  .timeline li {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 24px;
    padding: 20px;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    align-items: start;
  }
  .timeline__year {
    font-weight: 800;
    color: var(--color-primary);
    font-size: 1.25rem;
  }
  .timeline__body h3 { margin: 0 0 4px; }
  .timeline__body p { color: var(--color-text-muted); margin: 0; }
  @media (max-width: 540px) {
    .timeline li { grid-template-columns: 1fr; gap: 4px; }
  }
</style>
