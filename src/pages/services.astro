---
import Layout from "../layouts/Layout.astro";

const groups = [
  {
    title: "Suspension, Steering & Alignment",
    desc: "Complicated alignments are our specialty. We handle all alignments from lifted and lowered vehicles to motorhomes and small buses.",
    items: [
      "Computerized 4-wheel alignment",
      "Shocks, struts & strut&nbsp;mounts",
      "Control arms, ball joints,&nbsp;bushings",
      "Tie rods, idler & pitman&nbsp;arms",
      "Power steering pumps &amp;&nbsp;racks",
    ],
  },
  {
    title: "Brakes",
    desc: "Pads, rotors, calipers, hoses, master cylinders, lines, and ABS diagnostics — all with a free safety inspection.",
    items: [
      "Brake pad &amp; rotor&nbsp;replacement",
      "Caliper rebuild &amp;&nbsp;replacement",
      "Brake fluid&nbsp;flush",
      "ABS diagnosis &amp;&nbsp;repair",
      "Parking brake&nbsp;service",
      "Brake hose &amp; line&nbsp;replacement",
    ],
  },
  {
    title: "Tires & Balancing",
    desc: "Tire mounting, road-force balancing, rotations and pressure-monitor service.",
    items: [
      "Tire mounting &amp;&nbsp;balancing",
      "Road-force&nbsp;balancing",
      "Tire rotation &amp; pressure&nbsp;check",
      "TPMS&nbsp;service",
      "Tire repair (when&nbsp;safe)",
    ],
  },
  {
    title: "Engine, Diagnostics & Electrical",
    desc: "Modern cars are computers on wheels. Our techs read, repair, and re-program them.",
    items: [
      "Check-engine light&nbsp;diagnosis",
      "Tune-ups &amp; ignition&nbsp;service",
      "Engine repair &amp;&nbsp;rebuild",
      "Alternators &amp;&nbsp;starters",
      "Battery testing &amp;&nbsp;replacement",
      "Electrical troubleshooting",
    ],
  },
  {
    title: "Cooling, Heating & A/C",
    desc: "Keep your engine and your cabin at the right temperature.",
    items: [
      "Radiator &amp; water&nbsp;pump",
      "Coolant&nbsp;flush",
      "Hoses &amp thermostat",
      "Heater core&nbsp;service",
      "A/C diagnosis &amp;&nbsp;recharge",
    ],
  },
  {
    title: "Performance & Upgrades",
    desc: "Brake & suspension upgrades, electrical upgrades, and performance tuning for street cars.",
    items: [
      "Performance suspension installs",
      "Brake&nbsp;upgrades",
      "Electrical &amp; lighting upgrades",
      "Performance tuning",
    ],
  },
];
---
<Layout title="Services — Tyerman's Automotive & Suspension">
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Services</span>
      <h1>Everything from a wheel alignment to a full engine rebuild.</h1>
      <p>
        We're best known for suspension and alignment, but our 13-bay shop
        handles complete mechanical service for nearly every make and model
        on the road today.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid--2">
        {groups.map((g) => (
          <article class="service-card">
            <h2>{g.title}</h2>
            <p>{g.desc}</p>
            <ul>
              {g.items.map((i) => <li set:html={i} />)}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--dark">
    <div class="container cta">
      <div>
        <h2>Don't see what you need?</h2>
        <p>If we can't do it, we'll point you to someone we trust who can. Give us a call.</p>
      </div>
      <div style="display:flex; gap:12px; flex-wrap:wrap;">
        <a href="tel:+18188467291" class="btn btn--inverse">(818) 846-7291</a>
        <a href="/appointment" class="btn btn--primary">Request an appointment</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    padding: 72px 0 32px;
    background: linear-gradient(180deg, var(--color-bg-subtle) 0%, var(--color-bg) 100%);
  }
  .page-hero h1 { max-width: 22ch; }
  .page-hero p {
    color: var(--color-text-muted);
    max-width: 64ch;
    font-size: 1.08rem;
  }

  .service-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 28px;
    box-shadow: var(--shadow-sm);
  }
  .service-card h2 {
    font-size: 1.4rem;
    margin-bottom: 8px;
  }
  .service-card p {
    color: var(--color-text-muted);
    margin-bottom: 16px;
  }
  .service-card ul {
    list-style: none;
    padding: 0;
    margin: 0;
    columns: 2;
    column-gap: 16px;
  }
  .service-card li {
    break-inside: avoid;
  }
  .service-card li {
    padding-left: 18px;
    position: relative;
    color: var(--color-text);
    font-size: 0.95rem;
    line-height: 1.7;
  }
  .service-card li::before {
    content: "\2022";
    position: absolute;
    left: 0;
    color: var(--color-primary);
    font-weight: 800;
  }

  .cta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }
  .cta p { margin: 0; }

  @media (max-width: 700px) {
    .service-card ul { columns: 1; }
  }
</style>
