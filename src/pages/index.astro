---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import heroImg from "../assets/tyermans-home.jpg";

const services = [
  { icon: "⚙️", title: "Wheel Alignment", desc: "Computerized 4-wheel alignment to keep tires wearing evenly and your car tracking straight. From lifted, lowered, and even motorhomes, we handle all your alignment needs." },
  { icon: "🛠️", title: "Suspension & Steering", desc: "Shocks, struts, control arms, ball joints, tie rods — the work we've specialized in for 75+ years." },
  { icon: "🛑", title: "Brakes", desc: "Complete brake service: pads, rotors, calipers, lines and ABS diagnostics." },
  { icon: "🔧", title: "Engine & Diagnostics", desc: "Tune-ups, check-engine diagnostics, electronic troubleshooting and engine repair." },
  { icon: "🛞", title: "Tires & Balancing", desc: "Tire mounting, road-force balancing, rotations and pressure checks." },
  { icon: "❄️", title: "Cooling & Heating", desc: "Radiators, water pumps, hoses, A/C and heater service." },
];
---
<Layout>
  <!-- HERO -->
  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__copy">
        <span class="eyebrow">Burbank, CA &middot; Since 1948</span>
        <h1>Honest auto repair from a family that's been here for over 75 years.</h1>
        <p>
          Tyerman's Automotive &amp; Suspension is a 13-bay shop on Magnolia Blvd
          specializing in wheel alignment, suspension, brakes, and complete
          mechanical service. Drop the keys with people who've been doing this
          longer than most shops have been open.
        </p>
        <div class="hero__cta">
          <a href="/appointment" class="btn btn--primary">Request appointment</a>
          <a href="tel:+18188467291" class="btn btn--ghost">📞 (818) 846-7291</a>
        </div>
        <ul class="hero__badges">
          <li>✓ ASE-trained technicians</li>
          <li>✓ 13 service bays</li>
          <li>✓ Family-owned &amp; operated</li>
        </ul>
      </div>
      <div class="hero__media" aria-hidden="true">
        <Image
          src={heroImg}
          alt="Tyerman's Automotive & Suspension shop in Burbank, CA"
          loading="eager"
          widths={[600, 900, 1200]}
          sizes="(max-width: 880px) 100vw, 50vw"
        />
      </div>
    </div>
  </section>

  <!-- SERVICES PREVIEW -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <div>
          <span class="eyebrow">What we do</span>
          <h2>Full-service auto care, with a specialty.</h2>
        </div>
        <a href="/services" class="btn btn--ghost">All services →</a>
      </div>
      <div class="grid grid--3" style="margin-top: 32px;">
        {services.map((s) => (
          <article class="card">
            <span class="icon-circle">{s.icon}</span>
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    padding: 72px 0 64px;
    background: linear-gradient(180deg, var(--color-bg-subtle) 0%, var(--color-bg) 100%);
  }
  .hero__inner {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 48px;
  }
  .hero__copy h1 { margin-bottom: 16px; }
  .hero__copy p { font-size: 1.08rem; color: var(--color-text); max-width: 56ch; }
  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin: 12px 0 28px;
  }
  .hero__badges {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    color: var(--color-text);
    font-size: 0.95rem;
  }
  .hero__media img {
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    width: 100%;
    height: auto;
    display: block;
  }

  @media (max-width: 880px) {
    .hero__inner { grid-template-columns: 1fr; }
  }

  .section-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 16px;
    flex-wrap: wrap;
  }
  .section-head h2 { margin: 0; }


  .cta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }
  .cta p { margin: 0; }
</style>
